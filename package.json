{
  "name": "claude-universal-custom-proxy",
  "version": "0.5.1",
  "description": "Local Anthropic Messages gateway that routes Claude-style model names to Ollama Cloud, Hugging Face Inference Router, NVIDIA NIM, OpenAI, Gemini, Qwen, DeepSeek, Moonshot/Kimi, Z.AI/GLM, Xiaomi MiMo, or Anthropic upstreams with smart Claude family fallback.",
  "private": true,
  "type": "module",
  "keywords": [
    "claude",
    "claude-desktop",
    "claude-code",
    "mcpb",
    "gateway",
    "proxy",
    "anthropic",
    "anthropic-messages",
    "nvidia",
    "nvidia-nim",
    "nim",
    "ollama",
    "ollama-cloud",
    "huggingface",
    "hf",
    "hf-router",
    "deepseek",
    "kimi",
    "moonshot",
    "glm",
    "zai",
    "mimo",
    "openai",
    "gemini",
    "qwen"
  ],
  "scripts": {
    "build:mcpb": "node scripts/build-mcpb.mjs",
    "launch-agent:install": "node scripts/install-launch-agent.mjs",
    "launch-agent:uninstall": "node scripts/uninstall-launch-agent.mjs",
    "start": "node proxy.mjs",
    "test": "node --test"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "archiver": "^8.0.0",
    "dotenv": "^17.4.2"
  }
}
