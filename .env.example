# =============================================================================
# Claude Model Proxy — environment template
#
# Copy to `.env` and uncomment / fill in only what you need. Every value below
# has a sensible default baked into proxy.mjs, so an empty .env is valid as
# long as at least one provider has an API key set.
#
# Three common setups:
#
#   A) Ollama-only (no Anthropic key) — recommended for free/low-cost usage.
#      Set OLLAMA_API_KEY + DEFAULT_PROVIDER=ollama. The proxy auto-translates
#      Claude Desktop's internal Haiku/Sonnet/Opus calls (including dated
#      aliases like claude-haiku-4-5-20251001) into Ollama Cloud models via the
#      CLAUDE_*_MODEL fallbacks.
#
#   B) HuggingFace-only — set HUGGINGFACE_API_KEY (or HF_TOKEN) and override
#      CLAUDE_HAIKU_MODEL/SONNET/OPUS to hf-* aliases. The HuggingFace
#      Inference Router auto-picks the underlying provider (Together,
#      Fireworks, HF Inference, Hyperbolic, SambaNova, Novita, Nebius) per
#      model.
#
#   C) Ollama + HuggingFace mixed — set both keys; pick ollama-* or
#      hf-* aliases per session in Claude Desktop's model dropdown.
#      Both providers run side-by-side; nothing else needs to change.
#
#   D) Multi-provider — set keys for each provider you want; the model map
#      decides routing (deepseek-* → DeepSeek, ollama-* → Ollama,
#      hf-* → HuggingFace, etc.). DEFAULT_PROVIDER is only used for
#      unmapped models.
#
#   E) Anthropic + extras — set ANTHROPIC_API_KEY so claude-haiku-4-5 /
#      claude-sonnet-4-6 / claude-opus-4-7 hit real Anthropic, and add any
#      proxy aliases (ollama-*, hf-*, deepseek-*, …) as
#      overflow.
# =============================================================================

# -----------------------------------------------------------------------------
# Gateway-facing proxy settings
# -----------------------------------------------------------------------------
BASE_URL=http://127.0.0.1:8787
PORT=8787

# Set DEBUG_PROXY=true to print incoming requests, routing decisions, and
# upstream responses. Off by default. Leave off in production — request bodies
# can be large.
DEBUG_PROXY=false

# Provider used for any model not found in the routing table. Common values:
#   ollama, huggingface, deepseek, moonshot, glm, xiaomi, openai, gemini,
#   qwen, anthropic.
# For an Ollama-only setup use DEFAULT_PROVIDER=ollama.
# For an HF-only setup use DEFAULT_PROVIDER=huggingface.
DEFAULT_PROVIDER=ollama

# When true, the proxy rewrites upstream model ids back to the Claude alias
# the client asked for in every response body and SSE event. Set to true if
# Claude Desktop's gateway gets confused by seeing the raw upstream id
# (e.g. "qwen3-coder:480b-cloud") in the response.model field; leave at the
# default (false) to pass upstream model ids through unchanged.
# REWRITE_RESPONSES=false

# -----------------------------------------------------------------------------
# Ollama Cloud (Turbo)
# Get key at https://ollama.com/settings/keys — no local install required.
# -----------------------------------------------------------------------------
OLLAMA_BASE_URL=https://ollama.com/v1
OLLAMA_API_KEY=

# -----------------------------------------------------------------------------
# HuggingFace Inference Router
# Get a token at https://huggingface.co/settings/tokens (read access is enough).
# The router auto-routes to Together, Fireworks, HF Inference, Hyperbolic,
# SambaNova, Novita, Nebius, etc. — whichever currently has the model live.
# Either HUGGINGFACE_API_KEY, HF_API_KEY, or HF_TOKEN is accepted.
# -----------------------------------------------------------------------------
HUGGINGFACE_BASE_URL=https://router.huggingface.co/v1
HUGGINGFACE_API_KEY=

# -----------------------------------------------------------------------------
# NVIDIA NIM (build.nvidia.com)
# Free API tier — sign up at https://build.nvidia.com/ and generate a key
# prefixed nvapi-. Provides Llama 3.x and 4.x, DeepSeek R1/V3.x/V4, Nemotron,
# Qwen 2.5 / 3, Mixtral, Phi-3.5/4, Gemma 2, Granite, Codestral, and ~30 more
# free models on the same OpenAI-compatible /v1/chat/completions surface.
# NVIDIA_API_KEY, NVAPI_KEY, and NIM_API_KEY are all accepted.
# Use nim-* aliases (see MODEL_MAP in proxy.mjs) to route here.
# -----------------------------------------------------------------------------
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_API_KEY=

# -----------------------------------------------------------------------------
# Claude family fallback — when ANTHROPIC_API_KEY is empty, any incoming
# claude-haiku-*, claude-sonnet-*, claude-opus-* (including dated variants
# like claude-haiku-4-5-20251001) is mapped to the alias below. The proxy
# then routes that alias through your normal provider chain.
#
# Defaults route Haiku → Qwen3 Coder Next, Sonnet → Qwen3 Coder 480B,
# Opus → GPT-OSS 120B on Ollama Cloud. Override with any Claude alias from
# the MODEL_MAP (e.g. deepseek-v4-pro, glm-5.1, …).
#
# For an HF-only setup, point them at hf-* aliases, e.g.:
#   CLAUDE_HAIKU_MODEL=hf-llama-3.1-8b
#   CLAUDE_SONNET_MODEL=hf-qwen-2.5-coder-32b
#   CLAUDE_OPUS_MODEL=hf-llama-3.1-405b
# -----------------------------------------------------------------------------
# CLAUDE_HAIKU_MODEL=ollama-qwen3-coder-next
# CLAUDE_SONNET_MODEL=ollama-qwen3-coder
# CLAUDE_OPUS_MODEL=ollama-gpt-oss-120b

# -----------------------------------------------------------------------------
# Anthropic Messages-compatible providers
# -----------------------------------------------------------------------------
# DeepSeek
# DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic
# DEEPSEEK_API_KEY=

# Moonshot / Kimi
# MOONSHOT_BASE_URL=https://api.moonshot.cn/anthropic
# MOONSHOT_API_KEY=

# Z.AI / GLM (ZAI_API_KEY and ZHIPU_API_KEY also accepted)
# GLM_BASE_URL=https://api.z.ai/api/anthropic
# GLM_API_KEY=

# Xiaomi MiMo (MIMO_API_KEY also accepted)
# XIAOMI_BASE_URL=https://api.xiaomimimo.com/anthropic
# XIAOMI_API_KEY=

# Anthropic native (only needed if you want claude-haiku-4-5 / sonnet / opus
# to hit real Anthropic instead of using the family fallback above)
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_API_KEY=
# ANTHROPIC_VERSION=2023-06-01

# -----------------------------------------------------------------------------
# OpenAI-compatible providers
# -----------------------------------------------------------------------------
# OpenAI
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=

# Google Gemini (OpenAI-compatible surface; GOOGLE_API_KEY also accepted)
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# GEMINI_API_KEY=

# Alibaba Qwen / DashScope (DASHSCOPE_API_KEY also accepted)
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# QWEN_API_KEY=

# -----------------------------------------------------------------------------
# Advanced — override or extend the built-in routing tables.
# All three accept a JSON object. The defaults in proxy.mjs already cover the
# full Ollama Cloud catalog with the required `-cloud` / `:cloud` suffixes,
# so most users don't need to touch these.
# -----------------------------------------------------------------------------
# MODEL_MAP={"claude-custom":"some-upstream:cloud"}
# MODEL_ALIASES={"some-upstream:cloud":"claude-custom"}
# MODEL_ROUTES={"claude-custom":"ollama"}

# Single JSON blob for MCPB installs that only expose one "advanced" field.
# Same keys as the env vars above, e.g.
# ADVANCED_ENV={"GLM_API_KEY":"...","ANTHROPIC_API_KEY":"sk-ant-..."}
