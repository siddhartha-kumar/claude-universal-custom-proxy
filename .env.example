GATEWAY_ENVIRONMENT=development
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8080
GATEWAY_LOG_LEVEL=INFO
GATEWAY_AUTH_ENABLED=true
GATEWAY_API_KEYS=change-this-before-use
GATEWAY_CONFIG_FILE=config/default.yaml

# When a /v1/messages request arrives with a claude-* model id that doesn't
# match any configured route, the gateway substitutes this model id for
# routing. Leave blank to return 404 for unknown claude-* models.
GATEWAY_ANTHROPIC_DEFAULT_MODEL=ollama-cloud/gemma3:4b

OPENAI_API_KEY=
DEEPSEEK_API_KEY=
PERPLEXITY_API_KEY=
KIMI_API_KEY=
ZAI_API_KEY=
HF_TOKEN=
OLLAMA_CLOUD_API_KEY=

OLLAMA_LOCAL_BASE_URL=http://localhost:11434
OLLAMA_CLOUD_BASE_URL=https://ollama.com
