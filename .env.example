# Local proxy
PORT=8787
BASE_URL=http://127.0.0.1:8787

# ── Your active providers ────────────────────────────────
OLLAMA_BASE_URL=https://ollama.com/v1
OLLAMA_API_KEY=your-ollama-key

HUGGINGFACE_BASE_URL=https://router.huggingface.co/v1
HUGGINGFACE_API_KEY=hf_your-token

NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_API_KEY=nvapi-your-key

# ── Other providers (uncomment to enable) ────────────────
# DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic
# DEEPSEEK_API_KEY=

# MOONSHOT_BASE_URL=https://api.moonshot.cn/anthropic
# MOONSHOT_API_KEY=

# GLM_BASE_URL=https://api.z.ai/api/anthropic
# GLM_API_KEY=

# XIAOMI_BASE_URL=https://api.xiaomimimo.com/anthropic
# XIAOMI_API_KEY=

# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_API_KEY=

# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=

# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# GEMINI_API_KEY=

# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# QWEN_API_KEY=

# ── Optional overrides ──────────────────────────────────
# Provider used for any model not in the routing table. Auto-falls-back to a
# provider that has a key if the one named here doesn't.
# DEFAULT_PROVIDER=ollama

# When ANTHROPIC_API_KEY is empty, native Claude models (and the dated ids the
# desktop app emits) are rerouted to these free aliases. Pick any alias from
# /v1/models — for example a HuggingFace or NVIDIA one.
# CLAUDE_HAIKU_MODEL=ollama-gpt-oss-20b
# CLAUDE_SONNET_MODEL=ollama-qwen3-coder-480b
# CLAUDE_OPUS_MODEL=ollama-gpt-oss-120b

# DEBUG_PROXY=true
# REWRITE_RESPONSES=true

# Add or override individual model routes (JSON: alias -> upstream id / provider).
# MODEL_MAP={"my-alias":"gpt-oss:20b"}
# MODEL_ROUTES={"my-alias":"ollama"}