# Default to LF for text files committed to the repository
* text=auto eol=lf

# Explicit text files
*.py     text eol=lf
*.toml   text eol=lf
*.yaml   text eol=lf
*.yml    text eol=lf
*.md     text eol=lf
*.sh     text eol=lf
*.conf   text eol=lf
*.cfg    text eol=lf
*.ini    text eol=lf
*.service text eol=lf
*.plist  text eol=lf
Dockerfile text eol=lf
Makefile text eol=lf

# PowerShell files keep CRLF for native execution on Windows
*.ps1    text eol=crlf
*.psm1   text eol=crlf
*.psd1   text eol=crlf

# Binary files
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.pdf    binary
